# Path to Harmony installation (e.g. /Applications/Toon Boom Harmony 24 Premium or C:\Program Files\Toon Boom Animation\Toon Boom Harmony 24 Premium)
HARMONY_INSTALL=

# Paths to Harmony binaries (optional, will auto-detect if empty)
HARMONY_CC_BIN=
HARMONY_BIN=
HARMONY_PYTHON_PACKAGES=

# Control Center connection details (Telnet / Script Server mode)
HARMONY_CC_HOST=127.0.0.1
HARMONY_CC_PORT=1234
HARMONY_CC_USER=usabatch

# Execution options
HARMONY_SCRIPT_TIMEOUT_MS=10000

# Safety and access restrictions
HARMONY_DRY_RUN_DEFAULT=true
HARMONY_ALLOW_DESTRUCTIVE=false
HARMONY_ALLOW_RAW_SCRIPTS=false

# Comma-separated list of absolute paths allowed for operations
HARMONY_ALLOWED_ROOTS=/Users/romanmolodyko/Documents/toon-boom-harmony-mcp,/tmp

# Log settings
HARMONY_LOG_DIR=./logs

# Video reconstruction core (separate Python process)
RECONSTRUCTION_CORE_URL=http://127.0.0.1:8765
RECONSTRUCTION_CACHE_ROOT=./output/reconstruction-cache
RECONSTRUCTION_MODEL_ROOT=./models/reconstruction
RECONSTRUCTION_DEVICE=cpu
RECONSTRUCTION_MAX_CONCURRENT_JOBS=1
RECONSTRUCTION_REQUEST_TIMEOUT_MS=600000
RECONSTRUCTION_MAX_DURATION_SECONDS=300
RECONSTRUCTION_MAX_WIDTH=4096
RECONSTRUCTION_MAX_HEIGHT=4096
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
